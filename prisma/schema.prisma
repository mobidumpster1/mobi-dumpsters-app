// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A staff login. "owner" has unrestricted access regardless of the
// permission flags below — those only apply to "staff" accounts, and exist
// so day-to-day operational work (bookings, equipment, customers, mileage)
// stays open to staff by default while money-touching and destructive
// actions stay owner-only unless explicitly granted. `active: false` locks
// a user out immediately (checked on every request, not just at login)
// without touching their historical AuditLog entries.
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("staff") // owner | staff
  active       Boolean  @default(true)

  // Staff-only permission grants — ignored for role "owner".
  canManageInvoices Boolean @default(false) // create/edit invoices, mark paid, send payment links
  canDeleteRecords  Boolean @default(false) // delete bookings/customers/equipment/invoices/leads
  canManageExpenses Boolean @default(false) // expenses + recurring bills
  canViewReports    Boolean @default(false) // profit report
  canManageLeads    Boolean @default(false) // Leads page

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
}

// A record of a sensitive action for accountability — who marked an invoice
// paid, who deleted a booking, etc. Append-only; never edited or deleted
// alongside the user who caused it, so deactivating a user doesn't erase
// what they did.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g. "invoice.marked_paid", "booking.deleted"
  entity    String   // e.g. "Invoice", "Booking"
  entityId  String?
  createdAt DateTime @default(now())
}

// An editable override for one of the app's automated customer emails
// (delivery, pickup, reminders, etc). Keyed by a fixed set of template
// keys defined in src/lib/emailTemplates.ts — if no row exists for a key,
// the hardcoded default in that file is used instead.
model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  body      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// A customer of the business. Kept simple for v1: one address per
// customer. Per-booking delivery addresses can differ from this.
model Customer {
  id          String   @id @default(cuid())
  name        String
  companyName String?
  phone       String?
  email       String?
  address     String?
  // Geocoded from address for the all-customers map view. Null until
  // geocoding succeeds (e.g. no address on file, or no Maps API key yet).
  latitude    Float?
  longitude   Float?
  notes       String?
  // Comma-separated labels (e.g. "Residential,Repeat") shown as pills in the UI.
  tags        String   @default("")
  // How this customer found us — google_ads | meta_ads | b2b_outreach |
  // referral | organic_search | repeat | other. Null means not specified
  // rather than forcing a guess. Set automatically to "b2b_outreach" when
  // converted from a Lead; otherwise picked from a dropdown at creation.
  leadSource  String?
  // Set once this customer exists in QuickBooks (created here, imported
  // from QuickBooks, or matched during a sync), so we don't create dupes.
  quickbooksCustomerId String?
  // Set when a Win-Back campaign email is sent to this customer, so the
  // page can show it's already been reached out to recently.
  lastWinBackEmailSentAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings        Booking[]
  equipmentOnHand EquipmentItem[]
  communications  CustomerNote[]
  locationEvents  EquipmentLocationEvent[]
  invoices        Invoice[]
  photos          CustomerPhoto[]
  signedAgreements SignedAgreement[]
  dumpLogEntries  DumpLogEntry[]
  creditEntries   CustomerCreditEntry[]
}

// One dump event for a customer's rental — a customer can request more
// than one dump during a single booking, each with its own weight and fee.
model DumpLogEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id])
  date       DateTime
  weightTons Float
  fee        Float
  notes      String?
  createdAt  DateTime @default(now())
}

// A running credit balance per customer (e.g. from an overpayment or a
// goodwill adjustment), applied toward a future rental. The balance is the
// sum of these entries rather than a stored counter, so it's always
// auditable — positive amounts add credit, negative amounts use it up.
model CustomerCreditEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Float
  reason     String
  createdAt  DateTime @default(now())
}

// A single entry in a customer's communication timeline (a note, or a
// logged call/text), newest first.
model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   @default("note") // note | call | text | email
  content    String
  createdAt  DateTime @default(now())
}

model CustomerPhoto {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   @default("other") // property | id | contract | other
  mediaType  String   @default("photo") // photo | video
  caption    String?
  filePath   String
  createdAt  DateTime @default(now())
}

// Defines a type of rentable thing (Roll-Off Dumpster, Excavator, Tiller...).
// fieldDefinitions holds a JSON array describing the extra fields that
// items in this category track, e.g.:
// [{"key":"sizeYards","label":"Size (yd)","type":"number","required":true}]
// New equipment types are added by creating a new category here, not by
// changing this schema.
model EquipmentCategory {
  id               String   @id @default(cuid())
  name             String   @unique
  description      String?
  // Shown next to this category on the public booking page, so customers
  // can see what they're actually renting.
  imageUrl         String?
  fieldDefinitions String   @default("[]")
  // How many days an item of this category can sit at one site before it's
  // flagged as "sitting too long" on the equipment dashboard.
  agingThresholdDays Int    @default(14)

  // Pricing rules used to auto-generate invoice line items. All optional —
  // a category only needs the rules relevant to it (e.g. an excavator may
  // skip tonnage, a dumpster may skip mileage).
  basePrice          Float?
  includedDays       Int?
  overageDayRate     Float?
  includedTonnage    Float?
  overageTonnageRate Float?
  includedMileage    Float?
  overageMileageRate Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Lets a category be a "bundle" that books multiple units of another
  // category instead of owning equipment itself — e.g. a public listing for
  // "40 Yard — Two Containers" that actually reserves 2 Roll-Off Dumpsters.
  bundleOfCategoryId String?
  bundleOfCategory   EquipmentCategory?  @relation("CategoryBundle", fields: [bundleOfCategoryId], references: [id])
  bundledAs          EquipmentCategory[] @relation("CategoryBundle")
  bundleQuantity     Int                 @default(1)

  items        EquipmentItem[]
  pricingTiers PricingTier[]
}

// A duration option shown on the public booking form, e.g. "24 Hour" / $199,
// "7 Day" / $329. Lets rental pricing match a real published rate card
// instead of one flat base price. A category with no tiers falls back to
// basePrice + freeform dates (used for custom-quote services).
model PricingTier {
  id         String            @id @default(cuid())
  categoryId String
  category   EquipmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label      String // e.g. "24 Hour", "7 Day"
  days       Int // rental length used to compute the pickup date
  // Null means "Call for pricing" — shown but not selectable online.
  price      Float?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

// A single physical unit you own (e.g. "Dumpster #1"). `attributes` holds
// a JSON object with values for whatever fields its category defines
// (e.g. {"sizeYards": 20, "maxWeightTons": 3} for a dumpster, or
// {"hourMeter": 812.5, "attachments": ["bucket","breaker"]} for an excavator).
model EquipmentItem {
  id         String            @id @default(cuid())
  categoryId String
  category   EquipmentCategory @relation(fields: [categoryId], references: [id])

  label      String
  assetTag   String?
  // available | reserved | out_on_job | in_transit | needs_repair | retired
  status     String  @default("available")
  attributes String  @default("{}")

  currentLocation   String?
  currentCustomerId String?
  currentCustomer   Customer? @relation(fields: [currentCustomerId], references: [id])

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingItems      BookingItem[]
  expenses          Expense[]
  locationEvents    EquipmentLocationEvent[]
  photos            EquipmentPhoto[]
  mileageLogEntries MileageLogEntry[]
  damageReports     DamageReport[]
}

// A company-owned vehicle (a truck used to tow/deliver equipment) —
// distinct from EquipmentItem, which is customer-rentable inventory shown
// on the public booking form. Vehicles are never bookable by customers.
model Vehicle {
  id        String   @id @default(cuid())
  label     String // e.g. "2004 F250"
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mileageLogEntries MileageLogEntry[]
  bookings          Booking[]
}

// A single trip's mileage — which truck drove it, and (optionally) which
// piece of rental equipment it was hauling. `miles` is the stored/derived
// total, computed from odometerStart/odometerEnd. Null miles/odometerEnd
// means the trip was started but hasn't been closed out yet. `source`
// exists so a future Samsara GPS sync can insert entries the same way
// without a schema change.
model MileageLogEntry {
  id              String         @id @default(cuid())
  vehicleId       String?
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])
  equipmentItemId String?
  equipmentItem   EquipmentItem? @relation(fields: [equipmentItemId], references: [id])
  date            DateTime
  odometerStart   Float?
  odometerEnd     Float?
  miles           Float?
  purpose         String
  bookingId       String?
  booking         Booking?       @relation(fields: [bookingId], references: [id])
  notes           String?
  source          String         @default("manual") // manual | samsara
  createdAt       DateTime       @default(now())
}

// A log of where a piece of equipment has been over time. A null endedAt
// means it's currently there — duration-at-current-site and the "sitting
// too long" flag are both computed from this.
model EquipmentLocationEvent {
  id              String        @id @default(cuid())
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id])
  location        String
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  createdAt       DateTime      @default(now())
}

// A permanent condition photo for a piece of equipment (damage, wear,
// repair documentation) — independent of any specific job, unlike the
// booking-scoped Photo model below.
model EquipmentPhoto {
  id              String        @id @default(cuid())
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id])
  type            String        @default("condition") // condition | damage | repair | other
  mediaType       String        @default("photo") // photo | video
  caption         String?
  filePath        String
  createdAt       DateTime      @default(now())
}

// A standalone photo/video uploaded straight from the Gallery page — not
// tied to a job, piece of equipment, or customer. For general shots
// (marketing, category photos, anything without an obvious home).
model GalleryPhoto {
  id        String   @id @default(cuid())
  mediaType String   @default("photo") // photo | video
  caption   String?
  filePath  String
  createdAt DateTime @default(now())
}

// A rental transaction for one customer. May include multiple pieces of
// equipment, each tracked independently via BookingItem.
model Booking {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  status          String   @default("confirmed") // quoted | confirmed | in_progress | completed | cancelled
  deliveryAddress String
  // Geocoded from deliveryAddress so it can be pinned on the dispatch map.
  // Null until geocoding succeeds (e.g. before a Maps API key is configured).
  latitude        Float?
  longitude       Float?
  notes           String?
  // Set once a Google Calendar event has been created for this booking, so
  // we don't create duplicates if the push is ever retried.
  googleCalendarEventId String?
  // Which truck handled this job — used to log its mileage once, instead of
  // per equipment item, when the job is closed out.
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  // Set once the daily review-request cron has emailed this customer, so a
  // booking never gets asked for a review twice.
  reviewRequestSentAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items    BookingItem[]
  invoices Invoice[]
  expenses Expense[]
  photos   Photo[]
  signedAgreements SignedAgreement[]
  mileageLogEntries MileageLogEntry[]
  dumpLogEntries DumpLogEntry[]
  damageReports DamageReport[]
  serviceRequests ServiceRequest[]
}

// A customer-initiated request against an active booking, made from the
// public "manage your rental" link — e.g. asking for more time, or for the
// unit to be emptied and brought back instead of a final pickup. Never
// auto-applied; staff review it and take the actual action (edit the
// booking, log a dump trip) themselves.
model ServiceRequest {
  id         String    @id @default(cuid())
  bookingId  String
  booking    Booking   @relation(fields: [bookingId], references: [id])
  type       String    // extension | dump_and_return
  details    String?
  status     String    @default("pending") // pending | resolved
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}

// Filed when a returned piece of equipment came back damaged. Estimated
// cost either gets added to the booking's invoice (billedToCustomer) or
// recorded as a business expense (the company eats the cost) — never both.
model DamageReport {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id])
  equipmentItemId   String
  equipmentItem     EquipmentItem @relation(fields: [equipmentItemId], references: [id])
  description       String
  estimatedCost     Float
  billedToCustomer  Boolean       @default(false)
  // Set to whichever record actually carries the cost, so deleting the
  // report can clean it up in the right place.
  invoiceLineItemId String?
  expenseId         String?
  createdAt         DateTime      @default(now())
}

// A photo or video attached to a booking (delivery/pickup condition,
// damage, etc.), stored in Vercel Blob and referenced by its URL.
model Photo {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  type      String   @default("other") // delivery | pickup | damage | other
  mediaType String   @default("photo") // photo | video
  caption   String?
  filePath  String
  createdAt DateTime @default(now())
}

// One piece of equipment within a booking. Dates and price live here
// (not on Booking) so items in the same booking can have independent
// schedules, e.g. a dumpster dropped today and a trailer dropped next week.
model BookingItem {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id])
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id])

  startDate          DateTime
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  deliveredAt        DateTime?
  pickedUpAt         DateTime?
  // Set once the daily reminder cron has emailed the customer about this
  // item's upcoming delivery, so it's never sent twice.
  deliveryReminderSentAt DateTime?

  // Entered by staff when closing out the job; compared against the
  // category's included limits to compute overage line items.
  actualTonnage Float?
  actualMileage Float?

  price     Float   @default(0)
  notes     String?
  createdAt DateTime @default(now())
}

// A simple invoice generated from a booking. bookingId/booking are optional
// so standalone historical invoices (e.g. imported from old records that
// predate this app) can exist with just a customer, no full booking.
model Invoice {
  id            String    @id @default(cuid())
  bookingId     String?
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  // Used when there's no booking — set on every invoice for convenience,
  // but especially load-bearing when bookingId is null.
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  invoiceNumber String    @unique
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  amount        Float
  status        String    @default("unpaid") // unpaid | paid | partial
  paidDate      DateTime?
  paymentMethod String?
  notes         String?
  // Set once pushed to QuickBooks — either on marking paid, or earlier if
  // sent for online payment (see onlinePaymentUrl), in which case markPaid
  // reuses this same QBO invoice instead of creating a second one.
  quickbooksInvoiceId String?
  quickbooksPaymentId String?
  // QuickBooks-hosted "pay this invoice online" link, set once a staff
  // member sends it — customers pay card/ACH directly on Intuit's page, so
  // no card data ever touches this app.
  onlinePaymentUrl    String?
  onlinePaymentSentAt DateTime?
  // Tracks the most recent automated overdue-payment reminder, so the daily
  // cron can space repeat nags out instead of re-sending every run.
  lastReminderSentAt DateTime?
  createdAt     DateTime  @default(now())

  lineItems InvoiceLineItem[]
}

// One line on an invoice — base rental, an overage charge, or an add-on.
// Invoice.amount is kept as the sum of these for quick display.
model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  description String
  amount      Float
  // base | overage_days | overage_tonnage | overage_mileage | addon | other
  type        String   @default("other")
  createdAt   DateTime @default(now())
}

// Money going out: fuel, dump fees, subcontractors, equipment purchases,
// maintenance, etc. Optionally tied to the job or piece of equipment it
// was incurred for, so profit can be broken down by booking or equipment.
model Expense {
  id       String   @id @default(cuid())
  vendor   String
  category String
  amount   Float
  date     DateTime
  dueDate  DateTime?
  status   String    @default("unpaid") // unpaid | paid
  paidDate DateTime?
  notes    String?

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  equipmentItemId String?
  equipmentItem   EquipmentItem? @relation(fields: [equipmentItemId], references: [id])

  // Set once pushed to QuickBooks (on marking paid).
  quickbooksPurchaseId String?

  receipts ExpenseReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseReceipt {
  id        String   @id @default(cuid())
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id])
  filePath  String
  createdAt DateTime @default(now())
}

// A bill that recurs on a schedule (loan payments, subscriptions,
// insurance, licensing) rather than a one-off Expense. Not auto-billed —
// staff use "Log as Expense" here to record it as a real Expense once it's
// actually paid, so recordkeeping stays accurate without manual re-entry.
model RecurringBill {
  id            String    @id @default(cuid())
  name          String // e.g. "Truck", "Google Ads"
  category      String // e.g. "Vehicle Payment", "Advertising"
  amount        Float? // null when variable (e.g. a credit card balance)
  frequency     String // monthly | yearly
  dueDay        Int? // day of month (1-31), for monthly bills
  dueDate       DateTime? // specific annual date, for yearly bills
  paymentMethod String?
  active        Boolean   @default(true)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// A single row holding the connection to the business's QuickBooks Online
// company, including which account/item new transactions should post to.
// Only exists once a "Connect to QuickBooks" flow has completed.
model QuickBooksConnection {
  id                        String   @id @default(cuid())
  realmId                   String
  accessToken               String
  refreshToken              String
  accessTokenExpiresAt      DateTime
  environment               String   @default("sandbox") // sandbox | production
  defaultDepositAccountId   String?
  defaultDepositAccountName String?
  defaultIncomeAccountId    String?
  defaultIncomeAccountName  String?
  defaultExpenseAccountId   String?
  defaultExpenseAccountName String?
  defaultItemId             String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// A single row holding the current service agreement text. Edited from
// Settings. Signing snapshots this text so historical signatures stay
// accurate even if the wording changes later.
model ServiceAgreementSettings {
  id        String   @id @default(cuid())
  title     String   @default("Service & Rental Agreement")
  content   String   @default("[Placeholder — replace this with your real service agreement text in Settings before sharing with customers. Consider having a lawyer review it.]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Controls the automated "please leave us a review" email sent a few days
// after a job is fully closed out. Singleton row, same pattern as
// ServiceAgreementSettings — created with defaults on first Settings visit.
model ReviewRequestSettings {
  id             String   @id @default(cuid())
  enabled        Boolean  @default(false)
  googleReviewUrl String?
  delayDays      Int      @default(2)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// Controls the automated overdue-invoice reminder email. Singleton row,
// same pattern as ReviewRequestSettings — created with defaults on first
// Settings visit.
model InvoiceReminderSettings {
  id         String   @id @default(cuid())
  enabled    Boolean  @default(false)
  delayDays  Int      @default(7) // days past due before the first reminder
  repeatDays Int      @default(14) // days between repeat reminders while still unpaid
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// Controls whether marking equipment delivered or picked up automatically
// emails the customer (pickup includes the dump weight when it was
// recorded). Singleton row, same pattern as the other *Settings models —
// created with defaults on first Settings visit.
model JobNotificationSettings {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Controls the automated "your delivery is coming up" reminder email, sent
// a configurable number of hours before a booking item's scheduled start.
// Singleton row, same pattern as ReviewRequestSettings.
model DeliveryReminderSettings {
  id          String   @id @default(cuid())
  enabled     Boolean  @default(false)
  hoursBefore Int      @default(24)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// One "search" click on the Leads page — logged purely so we can show how
// many of the monthly free Places API calls (1,000, Enterprise SKU) are
// left, computed as a count of these rather than a stored counter so it's
// always auditable and naturally resets when a new calendar month's
// entries are counted.
model PlacesSearchLog {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

// A local business found via a Google Places search, tracked for sales
// outreach — not a customer yet. Deduped by placeId so re-running a search
// over the same area doesn't create copies; a repeat search just leaves an
// existing lead's status/notes alone and refreshes its basic details.
model Lead {
  id          String    @id @default(cuid())
  placeId     String    @unique
  name        String
  phone       String?
  address     String?
  // Returned directly by the Places search itself (no separate geocoding
  // call needed) — used to plot leads on the map.
  latitude    Float?
  longitude   Float?
  website     String?
  category    String?
  // The business type as typed into the search box (e.g. "roofers"),
  // before any service area gets appended — kept separate from `category`
  // (Google's own, much noisier classification) so the filter tabs on the
  // Leads page can group by what the business actually searched for.
  tradeCategory String?
  rating      Float?
  searchQuery String?
  status      String    @default("new") // new | contacted | interested | not_interested | customer
  notes       String?
  contactedAt DateTime?
  // Google Places doesn't return email addresses, so this is filled in by
  // hand (usually found on the business's own website) before an outreach
  // email can be sent.
  email           String?
  lastEmailSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// A reusable outreach message for the Leads page — e.g. one for roofers,
// one for general contractors. {{businessName}} in the subject/body gets
// swapped for the lead's name when sent. Kept separate from EmailTemplate
// (which covers fixed system events like delivery/pickup) since these are
// freeform, user-created, and there can be any number of them.
model LeadEmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A reusable outreach message for the Win-Back page — e.g. "we miss you"
// with a discount. {{customerName}} in the subject/body gets swapped for
// the customer's name when sent. Kept as its own list, separate from
// LeadEmailTemplate, since cold-outreach messaging and win-back messaging
// read very differently even though the sending mechanism is identical.
model WinBackEmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Controls what counts as "lapsed" on the Win-Back page. Singleton row,
// same pattern as ReviewRequestSettings — created with defaults on first
// Settings visit. No enabled/automation flag: win-back is always a
// staff-triggered one-click send, never an automated cron.
model WinBackSettings {
  id         String   @id @default(cuid())
  lapsedDays Int      @default(90)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// A saved city/area (e.g. "Byron, GA") that Lead searches run against
// automatically, so a search only needs a business type ("roofers") instead
// of retyping the whole service area every time. A search with no saved
// areas just runs the typed query as-is.
model ServiceArea {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// A record of one customer agreeing to the service agreement — either as a
// required step of the online booking flow, or via a standalone link sent
// manually. Stores a snapshot of the exact text agreed to.
model SignedAgreement {
  id             String   @id @default(cuid())
  agreementTitle String
  agreementText  String
  signerName     String
  signerEmail    String?
  signerPhone    String?
  signerAddress  String?
  ipAddress      String?
  agreedAt       DateTime @default(now())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  bookingId  String?
  booking    Booking?  @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}
