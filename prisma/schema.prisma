// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One business using the app — the unit everything else (customers,
// bookings, invoices, leads, settings...) ultimately belongs to. Every
// installation today has exactly one row here (Mobi Dumpsters), but every
// tenant-owned table is built to carry an organizationId from day one so
// a second business can be onboarded later without retrofitting existing
// data. See src/lib/session.ts for how a logged-in request carries this.
model Organization {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String?
  primaryColor String?
  // The hostname (e.g. "book.mobidumpsters.com") that this org's public
  // /book and /agreement/sign pages are reached at — see
  // getPublicOrganizationId in src/lib/session.ts. Without this, those
  // pages had no way to tell organizations apart and just showed
  // whichever org happened to be first in the table.
  publicDomain String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Which subscription tier this organization is on — solo | team | pro.
  // Denormalized here (rather than only living on PlatformSubscription
  // below) so every gating check is a plain scalar read, no join, same
  // shape as the canManageX flags on User. Defaults to "solo" (free) —
  // only upgrading to team/pro ever creates a real PlatformSubscription row.
  plan                     String                     @default("solo")
  platformSubscription     PlatformSubscription?

  users                    User[]
  customers                Customer[]
  bookings                 Booking[]
  invoices                 Invoice[]
  expenses                 Expense[]
  recurringBills           RecurringBill[]
  equipmentCategories      EquipmentCategory[]
  equipmentItems           EquipmentItem[]
  vehicles                 Vehicle[]
  documents                Document[]
  mileageLogEntries        MileageLogEntry[]
  leads                    Lead[]
  galleryPhotos            GalleryPhoto[]
  serviceAreas             ServiceArea[]
  permitAreas              PermitArea[]
  emailSequences           EmailSequence[]
  leadEmailTemplates       LeadEmailTemplate[]
  winBackEmailTemplates    WinBackEmailTemplate[]
  placesSearchLogs         PlacesSearchLog[]
  emailTemplates           EmailTemplate[]
  quickBooksConnection     QuickBooksConnection?
  serviceAgreementSettings ServiceAgreementSettings?
  reviewRequestSettings    ReviewRequestSettings?
  invoiceReminderSettings  InvoiceReminderSettings?
  jobNotificationSettings  JobNotificationSettings?
  jobCostingSettings       JobCostingSettings?
  deliveryReminderSettings DeliveryReminderSettings?
  leadOutreachSettings     LeadOutreachSettings?
  winBackSettings          WinBackSettings?
  websiteSnippets          WebsiteSnippet[]
  stripeConnection         StripeConnection?
  twilioConnection         TwilioConnection?
  smsMessages              CustomerSmsMessage[]
  quotes                   Quote[]
  maintenanceLogEntries    MaintenanceLogEntry[]
  timeEntries              TimeEntry[]
  googleBusinessProfileConnection GoogleBusinessProfileConnection?
  googleReviews            GoogleReview[]
  automationRules          AutomationRule[]
  automationSettings       AutomationSettings?
  googleAdsConnection      GoogleAdsConnection?
  adsPerformance           AdsPerformance[]
  marketingRecommendations MarketingRecommendation[]
  searchConsoleConnection  SearchConsoleConnection?
  seoPerformance           SeoPerformance[]
}

// A staff login. "owner" has unrestricted access regardless of the
// permission flags below — those only apply to "staff" accounts, and exist
// so day-to-day operational work (bookings, equipment, customers, mileage)
// stays open to staff by default while money-touching and destructive
// actions stay owner-only unless explicitly granted. `active: false` locks
// a user out immediately (checked on every request, not just at login)
// without touching their historical AuditLog entries.
model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String
  role         String  @default("staff") // owner | staff
  active       Boolean @default(true)
  // Set once the /verify-email link is clicked. Existing accounts (seeded
  // owner logins, accounts created before this field existed) are
  // backfilled as already verified — this is about confirming a
  // freshly-typed signup email actually works, not re-litigating trust
  // in accounts Chase already controls.
  emailVerifiedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Staff-only permission grants — ignored for role "owner".
  canManageInvoices Boolean @default(false) // create/edit invoices, mark paid, send payment links
  canDeleteRecords  Boolean @default(false) // delete bookings/customers/equipment/invoices/leads
  canManageExpenses Boolean @default(false) // expenses + recurring bills
  canViewReports    Boolean @default(false) // profit report
  canManageLeads    Boolean @default(false) // Leads page

  // A support/maintenance capability, completely separate from the
  // per-organization owner/staff scale above — an owner controls their
  // own organization's staff; this controls whether a user can step
  // into *any* organization to help troubleshoot (see
  // src/lib/session.ts and src/app/(internal)/platform-admin/actions.ts).
  // Off for everyone by default, including owner accounts — must be
  // explicitly granted, and every use of it is audit-logged separately
  // from normal activity.
  isPlatformAdmin Boolean @default(false)

  // Track Time (Pro): a default hourly rate used to price this user's
  // clocked hours, and whether they can edit/delete other staff's time
  // entries (separate from canManageInvoices etc. since editing someone
  // else's clock record is a distinct trust level from booking work).
  hourlyRate    Float?
  canManageTime Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  timeEntries             TimeEntry[]
}

// A single-use, short-lived token emailed as a /verify-email?token=... link
// right after signup (and again on demand via the "Resend" button on the
// unverified-account banner). Only the sha256 hash is stored — same idea
// as password hashing, so a database leak alone can't be used to verify
// (or reset the password of) any account. Creating a new one deletes any
// prior unused token for the same user, so only the most recent link
// still works.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Same shape and single-use/hashed-token design as EmailVerificationToken,
// for the /forgot-password → email link → /reset-password flow. Kept as
// a separate model (rather than a shared "purpose" column) since the two
// have very different lifetimes (48h vs 1h) and very different blast
// radius if guessed.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// A record of a sensitive action for accountability — who marked an invoice
// paid, who deleted a booking, etc. Append-only; never edited or deleted
// alongside the user who caused it, so deactivating a user doesn't erase
// what they did.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // e.g. "invoice.marked_paid", "booking.deleted"
  entity    String // e.g. "Invoice", "Booking"
  entityId  String?
  createdAt DateTime @default(now())
}

// An editable override for one of the app's automated customer emails
// (delivery, pickup, reminders, etc). Keyed by a fixed set of template
// keys defined in src/lib/emailTemplates.ts — if no row exists for a key,
// the hardcoded default in that file is used instead.
model EmailTemplate {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  key            String
  subject        String
  body           String
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())

  @@unique([organizationId, key])
}

// A customer of the business. Kept simple for v1: one address per
// customer. Per-booking delivery addresses can differ from this.
model Customer {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  name                 String
  companyName          String?
  phone                String?
  email                String?
  address              String?
  // Geocoded from address for the all-customers map view. Null until
  // geocoding succeeds (e.g. no address on file, or no Maps API key yet).
  latitude             Float?
  longitude            Float?
  notes                String?
  // Comma-separated labels (e.g. "Residential,Repeat") shown as pills in the UI.
  tags                 String       @default("")
  // How this customer found us — google_ads | meta_ads | b2b_outreach |
  // referral | organic_search | repeat | other. Null means not specified
  // rather than forcing a guess. Set automatically to "b2b_outreach" when
  // converted from a Lead; otherwise picked from a dropdown at creation.
  leadSource           String?
  // Set once this customer exists in QuickBooks (created here, imported
  // from QuickBooks, or matched during a sync), so we don't create dupes.
  quickbooksCustomerId String?
  // Card on file, saved via Stripe Elements at booking time or from the
  // Customer detail page — only Stripe's own references are stored here,
  // never a raw card number. brand/last4 are display-only, safe to store.
  // One card per customer for now (not a separate table) — revisit if a
  // real need for multiple saved cards per customer shows up.
  stripeCustomerId      String?
  stripePaymentMethodId String?
  stripeCardBrand       String?
  stripeCardLast4       String?
  // A unique code for this customer's own referral link
  // (mobidumpsters.com/book?ref=<code>). Stored value is a plain cuid;
  // every place it's displayed/linked instead renders a short
  // human-friendly form via src/lib/referralCode.ts, so the actual shared
  // link is memorable without a second lookup column.
  referralCode         String       @unique @default(cuid())
  // Set once, at creation, from the ?ref= link that brought this customer
  // in — never overwritten later, same rule as leadSource. Self-relation:
  // the customer whose link was used.
  referredByCustomerId String?
  referredByCustomer   Customer?    @relation("CustomerReferrals", fields: [referredByCustomerId], references: [id])
  referredCustomers    Customer[]   @relation("CustomerReferrals")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  bookings         Booking[]
  equipmentOnHand  EquipmentItem[]
  communications   CustomerNote[]
  locationEvents   EquipmentLocationEvent[]
  invoices         Invoice[]
  photos           CustomerPhoto[]
  signedAgreements SignedAgreement[]
  dumpLogEntries   DumpLogEntry[]
  creditEntries    CustomerCreditEntry[]
  winBackSends     WinBackSend[]
  smsMessages      CustomerSmsMessage[]
  leads            Lead[]
  quotes           Quote[]
}

// One dump event for a customer's rental — a customer can request more
// than one dump during a single booking, each with its own weight and fee.
model DumpLogEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id])
  date       DateTime
  weightTons Float
  fee        Float
  notes      String?
  receiptUrl String?
  createdAt  DateTime @default(now())
}

// A running credit balance per customer (e.g. from an overpayment or a
// goodwill adjustment), applied toward a future rental. The balance is the
// sum of these entries rather than a stored counter, so it's always
// auditable — positive amounts add credit, negative amounts use it up.
model CustomerCreditEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Float
  reason     String
  createdAt  DateTime @default(now())
}

// A single entry in a customer's communication timeline (a note, or a
// logged call/text), newest first.
model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   @default("note") // note | call | text | email
  content    String
  createdAt  DateTime @default(now())
}

model CustomerPhoto {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   @default("other") // property | id | contract | other
  mediaType  String   @default("photo") // photo | video
  caption    String?
  filePath   String
  createdAt  DateTime @default(now())
}

// Defines a type of rentable thing (Roll-Off Dumpster, Excavator, Tiller...).
// fieldDefinitions holds a JSON array describing the extra fields that
// items in this category track, e.g.:
// [{"key":"sizeYards","label":"Size (yd)","type":"number","required":true}]
// New equipment types are added by creating a new category here, not by
// changing this schema.
model EquipmentCategory {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  name               String
  description        String?
  // Shown next to this category on the public booking page, so customers
  // can see what they're actually renting.
  imageUrl           String?
  // A single free-text physical size line (e.g. "16' L x 7' W x 4.5' H"),
  // shown on the public booking page. Deliberately separate from
  // fieldDefinitions/EquipmentItem.attributes below, which track real
  // per-unit specs (one dumpster's actual size can differ from another's)
  // — this is category-level marketing copy, the same for every unit.
  dimensions         String?
  // A short callout shown on the public booking page below the pricing
  // details — e.g. "Heavy material (concrete, dirt, brick, roofing): fill
  // is limited by weight — call before loading." Separate from
  // `description` so the short marketing blurb (shown on the browse grid)
  // and this longer usage note (shown on the review step) can differ.
  bookingNote        String?
  fieldDefinitions   String       @default("[]")
  // How many days an item of this category can sit at one site before it's
  // flagged as "sitting too long" on the equipment dashboard.
  agingThresholdDays Int          @default(14)

  // Pricing rules used to auto-generate invoice line items. All optional —
  // a category only needs the rules relevant to it (e.g. an excavator may
  // skip tonnage, a dumpster may skip mileage).
  basePrice          Float?
  includedDays       Int?
  overageDayRate     Float?
  includedTonnage    Float?
  overageTonnageRate Float?
  includedMileage    Float?
  overageMileageRate Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Lets a category be a "bundle" that books multiple units of another
  // category instead of owning equipment itself — e.g. a public listing for
  // "40 Yard — Two Containers" that actually reserves 2 Roll-Off Dumpsters.
  bundleOfCategoryId String?
  bundleOfCategory   EquipmentCategory?  @relation("CategoryBundle", fields: [bundleOfCategoryId], references: [id])
  bundledAs          EquipmentCategory[] @relation("CategoryBundle")
  bundleQuantity     Int                 @default(1)

  items           EquipmentItem[]
  pricingTiers    PricingTier[]
  materialOptions MaterialOption[]

  @@unique([organizationId, name])
}

// A duration option shown on the public booking form, e.g. "24 Hour" / $199,
// "7 Day" / $329. Lets rental pricing match a real published rate card
// instead of one flat base price. A category with no tiers falls back to
// basePrice + freeform dates (used for custom-quote services).
model PricingTier {
  id         String            @id @default(cuid())
  categoryId String
  category   EquipmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label      String // e.g. "24 Hour", "7 Day"
  days       Int // rental length used to compute the pickup date
  // Null means "Call for pricing" — shown but not selectable online.
  price      Float?
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
}

// A material a "material delivery"-style category sells by the unit (e.g.
// "Mulch (Black/Brown/Red)" at $55/yd) — lets the booking page offer a
// material + quantity picker with a live-calculated price instead of one
// flat category price, for categories where cost genuinely varies by what's
// ordered rather than by rental duration (see PricingTier for that case).
model MaterialOption {
  id           String            @id @default(cuid())
  categoryId   String
  category     EquipmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  unit         String // "yd", "ton", "bale", etc. — freeform, just a label
  pricePerUnit Float
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
}

// A single physical unit you own (e.g. "Dumpster #1"). `attributes` holds
// a JSON object with values for whatever fields its category defines
// (e.g. {"sizeYards": 20, "maxWeightTons": 3} for a dumpster, or
// {"hourMeter": 812.5, "attachments": ["bucket","breaker"]} for an excavator).
model EquipmentItem {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  categoryId     String
  category       EquipmentCategory @relation(fields: [categoryId], references: [id])

  label      String
  assetTag   String?
  // available | reserved | out_on_job | in_transit | needs_repair | retired
  status     String  @default("available")
  attributes String  @default("{}")

  currentLocation   String?
  currentCustomerId String?
  currentCustomer   Customer? @relation(fields: [currentCustomerId], references: [id])

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingItems      BookingItem[]
  expenses          Expense[]
  locationEvents    EquipmentLocationEvent[]
  photos            EquipmentPhoto[]
  mileageLogEntries MileageLogEntry[]
  damageReports     DamageReport[]
  quoteLineItems    QuoteLineItem[]
  maintenanceLogEntries MaintenanceLogEntry[]
}

// A company-owned vehicle (a truck used to tow/deliver equipment) —
// distinct from EquipmentItem, which is customer-rentable inventory shown
// on the public booking form. Vehicles are never bookable by customers.
model Vehicle {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  label          String // e.g. "2004 F250"
  active         Boolean      @default(true)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  mileageLogEntries MileageLogEntry[]
  bookings          Booking[]
  documents         Document[]
  maintenanceLogEntries MaintenanceLogEntry[]
}

// A compliance document with an expiry date — insurance policy, vehicle
// registration, DOT filing, business license, etc. — optionally tied to a
// specific truck (e.g. one registration per vehicle). No edit-in-place;
// like ExpenseReceipt/EquipmentPhoto, correcting a mistake means deleting
// and re-adding, which keeps the upload flow (and this model) simple.
model Document {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String // insurance | vehicle_registration | dot_filing | business_license | other
  name           String // e.g. "General Liability Policy" or "Truck 1 Registration"
  fileUrl        String
  expiresOn      DateTime
  notes          String?
  vehicleId      String?
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// A single trip's mileage — which truck drove it, and (optionally) which
// piece of rental equipment it was hauling. `miles` is the stored/derived
// total, computed from odometerStart/odometerEnd. Null miles/odometerEnd
// means the trip was started but hasn't been closed out yet. `source`
// exists so a future Samsara GPS sync can insert entries the same way
// without a schema change.
model MileageLogEntry {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])
  equipmentItemId String?
  equipmentItem   EquipmentItem? @relation(fields: [equipmentItemId], references: [id])
  date            DateTime
  odometerStart   Float?
  odometerEnd     Float?
  miles           Float?
  purpose         String
  bookingId       String?
  booking         Booking?       @relation(fields: [bookingId], references: [id])
  notes           String?
  source          String         @default("manual") // manual | samsara
  createdAt       DateTime       @default(now())
}

// A service/maintenance event for a company vehicle or piece of rental
// equipment — oil change, repair, inspection, etc. Distinct from Document
// (a compliance paper with an expiry date) and MileageLogEntry (a single
// trip's mileage): this is the repair/upkeep history itself. Dual-optional
// FK mirrors MileageLogEntry — exactly one of vehicleId/equipmentItemId is
// expected to be set, enforced in the action, not the schema.
model MaintenanceLogEntry {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?       @relation(fields: [vehicleId], references: [id])
  equipmentItemId   String?
  equipmentItem     EquipmentItem? @relation(fields: [equipmentItemId], references: [id])
  type              String // oil_change | tire_rotation | repair | inspection | other
  description       String
  date              DateTime
  cost              Float?
  vendor            String?
  odometerAtService Float?
  // Mirrors Document.expiresOn — same alert-banner mechanism (see
  // src/lib/maintenance.ts) gets reused for "service due soon."
  nextServiceDue    DateTime?
  receiptUrl        String?
  notes             String?
  createdAt         DateTime       @default(now())
}

// A log of where a piece of equipment has been over time. A null endedAt
// means it's currently there — duration-at-current-site and the "sitting
// too long" flag are both computed from this.
model EquipmentLocationEvent {
  id              String        @id @default(cuid())
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id])
  location        String
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  createdAt       DateTime      @default(now())
}

// A permanent condition photo for a piece of equipment (damage, wear,
// repair documentation) — independent of any specific job, unlike the
// booking-scoped Photo model below.
model EquipmentPhoto {
  id              String        @id @default(cuid())
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id])
  type            String        @default("condition") // condition | damage | repair | other
  mediaType       String        @default("photo") // photo | video
  caption         String?
  filePath        String
  createdAt       DateTime      @default(now())
}

// A standalone photo/video uploaded straight from the Gallery page — not
// tied to a job, piece of equipment, or customer. For general shots
// (marketing, category photos, anything without an obvious home).
model GalleryPhoto {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  mediaType      String       @default("photo") // photo | video
  caption        String?
  filePath       String
  createdAt      DateTime     @default(now())
}

// A rental transaction for one customer. May include multiple pieces of
// equipment, each tracked independently via BookingItem.
model Booking {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])
  customerId            String
  customer              Customer     @relation(fields: [customerId], references: [id])
  status                String       @default("confirmed") // quoted | confirmed | in_progress | completed | cancelled
  deliveryAddress       String
  // Geocoded from deliveryAddress so it can be pinned on the dispatch map.
  // Null until geocoding succeeds (e.g. before a Maps API key is configured).
  latitude              Float?
  longitude             Float?
  notes                 String?
  // Set once a Google Calendar event has been created for this booking, so
  // we don't create duplicates if the push is ever retried.
  googleCalendarEventId String?
  // Which truck handled this job — used to log its mileage once, instead of
  // per equipment item, when the job is closed out.
  vehicleId             String?
  vehicle               Vehicle?     @relation(fields: [vehicleId], references: [id])
  // Set once the daily review-request cron has emailed this customer, so a
  // booking never gets asked for a review twice.
  reviewRequestSentAt   DateTime?
  // Permit tracking for street placement — only relevant in certain
  // cities/counties (configured in Settings as PermitArea rows). Auto-set
  // true at creation when deliveryAddress matches one, but always
  // manually toggleable too, since address matching is a suggestion, not
  // the final word. A simple checklist, not a workflow: no approval
  // routing, no reminders.
  permitRequired        Boolean      @default(false)
  permitNumber          String?
  permitStatus          String? // requested | approved | denied
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  items             BookingItem[]
  invoices          Invoice[]
  expenses          Expense[]
  photos            Photo[]
  signedAgreements  SignedAgreement[]
  mileageLogEntries MileageLogEntry[]
  dumpLogEntries    DumpLogEntry[]
  damageReports     DamageReport[]
  serviceRequests   ServiceRequest[]
  quote             Quote?
  timeEntries       TimeEntry[]
}

// A customer-initiated request against an active booking, made from the
// public "manage your rental" link — e.g. asking for more time, or for the
// unit to be emptied and brought back instead of a final pickup. Never
// auto-applied; staff review it and take the actual action (edit the
// booking, log a dump trip) themselves.
model ServiceRequest {
  id         String    @id @default(cuid())
  bookingId  String
  booking    Booking   @relation(fields: [bookingId], references: [id])
  type       String // extension | dump_and_return
  details    String?
  status     String    @default("pending") // pending | resolved
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}

// Filed when a returned piece of equipment came back damaged. Estimated
// cost either gets added to the booking's invoice (billedToCustomer) or
// recorded as a business expense (the company eats the cost) — never both.
model DamageReport {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id])
  equipmentItemId   String
  equipmentItem     EquipmentItem @relation(fields: [equipmentItemId], references: [id])
  description       String
  estimatedCost     Float
  billedToCustomer  Boolean       @default(false)
  // Set to whichever record actually carries the cost, so deleting the
  // report can clean it up in the right place.
  invoiceLineItemId String?
  expenseId         String?
  createdAt         DateTime      @default(now())
}

// A photo or video attached to a booking (delivery/pickup condition,
// damage, etc.), stored in Vercel Blob and referenced by its URL.
model Photo {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  type      String   @default("other") // delivery | pickup | damage | other
  mediaType String   @default("photo") // photo | video
  caption   String?
  filePath  String
  createdAt DateTime @default(now())
}

// One piece of equipment within a booking. Dates and price live here
// (not on Booking) so items in the same booking can have independent
// schedules, e.g. a dumpster dropped today and a trailer dropped next week.
model BookingItem {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id])
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id])

  startDate              DateTime
  expectedReturnDate     DateTime
  actualReturnDate       DateTime?
  deliveredAt            DateTime?
  pickedUpAt             DateTime?
  // Set once the daily reminder cron has emailed the customer about this
  // item's upcoming delivery, so it's never sent twice.
  deliveryReminderSentAt DateTime?

  // Entered by staff when closing out the job; compared against the
  // category's included limits to compute overage line items.
  actualTonnage Float?
  actualMileage Float?

  price     Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
}

// A simple invoice generated from a booking. bookingId/booking are optional
// so standalone historical invoices (e.g. imported from old records that
// predate this app) can exist with just a customer, no full booking.
model Invoice {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  bookingId           String?
  booking             Booking?     @relation(fields: [bookingId], references: [id])
  // Used when there's no booking — set on every invoice for convenience,
  // but especially load-bearing when bookingId is null.
  customerId          String?
  customer            Customer?    @relation(fields: [customerId], references: [id])
  invoiceNumber       String       @unique
  issueDate           DateTime     @default(now())
  dueDate             DateTime?
  amount              Float
  status              String       @default("unpaid") // unpaid | paid | partial
  paidDate            DateTime?
  paymentMethod       String?
  notes               String?
  // Set once pushed to QuickBooks — either on marking paid, or earlier if
  // sent for online payment (see onlinePaymentUrl), in which case markPaid
  // reuses this same QBO invoice instead of creating a second one.
  quickbooksInvoiceId String?
  quickbooksPaymentId String?
  // Legacy QuickBooks-hosted "pay this invoice online" link — superseded by
  // Stripe (see stripePaymentIntentId below) but left in place for any
  // invoice that already has one, rather than migrating historical data.
  onlinePaymentUrl    String?
  onlinePaymentSentAt DateTime?
  // Set once a Stripe charge is created for this invoice (card-on-file
  // charge or a completed Checkout session) — prevents double-charging and
  // lets the webhook confirm/reconcile status without guessing which
  // invoice a given PaymentIntent belongs to.
  stripePaymentIntentId String?
  // Tracks the most recent automated overdue-payment reminder, so the daily
  // cron can space repeat nags out instead of re-sending every run.
  lastReminderSentAt  DateTime?
  createdAt           DateTime     @default(now())

  lineItems    InvoiceLineItem[]
  photos       InvoicePhoto[]
  installments InvoiceInstallment[]
}

// One line on an invoice — base rental, an overage charge, or an add-on.
// Invoice.amount is kept as the sum of these for quick display.
model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  description String
  amount      Float
  // base | overage_days | overage_tonnage | overage_mileage | addon | other
  type        String   @default("other")
  createdAt   DateTime @default(now())
}

// A file attached to an invoice (e.g. a signed proof of completion, a
// supplier receipt worth keeping with the bill). Same shape as Photo, but
// its own model per this codebase's convention of one dedicated model per
// parent type (see CustomerPhoto alongside the Booking-only Photo) rather
// than a shared polymorphic table.
model InvoicePhoto {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  type      String   @default("other")
  mediaType String   @default("photo") // photo | video
  caption   String?
  filePath  String
  createdAt DateTime @default(now())
}

// One scheduled partial payment against an Invoice (e.g. "Deposit" due at
// booking, "Balance" due at delivery). An Invoice with no installments
// behaves exactly as before (single full-amount charge) — every existing
// invoice/charge/webhook path keeps working unchanged.
model InvoiceInstallment {
  id                    String    @id @default(cuid())
  invoiceId             String
  invoice               Invoice   @relation(fields: [invoiceId], references: [id])
  label                 String // e.g. "Deposit", "Balance"
  amount                Float
  dueDate               DateTime?
  status                String    @default("pending") // pending | paid
  paidDate              DateTime?
  paymentMethod         String?
  stripePaymentIntentId String?
  createdAt             DateTime  @default(now())
}

// A price proposal sent to a Lead and/or Customer before any Booking
// exists — the pipeline's "close the deal" step. leadId/customerId are
// both optional and at least one is always set at creation: a cold-pipeline
// Lead with no Customer yet, or an existing repeat Customer getting a new
// job priced out, or (after the lead converts) both, pointing at the same
// person. publicToken is a plain bearer link (like the Stripe Checkout
// links already used here) — a quote link only lets someone view pricing
// and accept/decline, no account or payment mutation capability, so this
// doesn't need the hashed-token-table treatment EmailVerificationToken
// gets for a real account-security flow.
model Quote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  quoteNumber    String       @unique
  status         String       @default("draft") // draft | sent | accepted | declined | expired
  amount         Float
  // The real total based on which optional lines the customer kept at
  // acceptance — null until accepted. `amount` stays the original
  // full-price snapshot shown when sent.
  acceptedAmount Float?
  notes          String?
  // A rough requested date shown to the customer — not a scheduling
  // commitment. The Booking created on acceptance still lands in "pending"
  // for staff to confirm real dates, same as any other booking request.
  proposedDate DateTime?
  publicToken  String    @unique @default(cuid())
  sentAt       DateTime?
  respondedAt  DateTime?
  // Set once acceptance has created a real Booking, so the public page and
  // staff UI can link straight to it instead of just showing "Accepted".
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems QuoteLineItem[]
  photos    QuotePhoto[]
}

// One line on a quote — either priced against a real EquipmentItem (which
// lets acceptance build a real BookingItem to reserve) or a free-text line
// with no equipmentItemId, which becomes a booking-level note instead.
model QuoteLineItem {
  id              String         @id @default(cuid())
  quoteId         String
  quote           Quote          @relation(fields: [quoteId], references: [id])
  equipmentItemId String?
  equipmentItem   EquipmentItem? @relation(fields: [equipmentItemId], references: [id])
  description     String
  amount          Float
  quantity        Float          @default(1)
  // A customer-selectable add-on shown pre-checked on the public quote
  // page (opt-out, not opt-in) — deselecting it excludes the line from
  // acceptedAmount and the booking notes summary built at acceptance.
  optional        Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

// A file attached to a quote (e.g. a reference photo of the job site).
// Same shape/rationale as InvoicePhoto — its own dedicated model rather
// than a shared polymorphic table.
model QuotePhoto {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  type      String   @default("other")
  mediaType String   @default("photo") // photo | video
  caption   String?
  filePath  String
  createdAt DateTime @default(now())
}

// Money going out: fuel, dump fees, subcontractors, equipment purchases,
// maintenance, etc. Optionally tied to the job or piece of equipment it
// was incurred for, so profit can be broken down by booking or equipment.
model Expense {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  vendor         String
  category       String
  amount         Float
  date           DateTime
  dueDate        DateTime?
  status         String       @default("unpaid") // unpaid | paid
  paidDate       DateTime?
  notes          String?

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  equipmentItemId String?
  equipmentItem   EquipmentItem? @relation(fields: [equipmentItemId], references: [id])

  // Set once pushed to QuickBooks (on marking paid).
  quickbooksPurchaseId String?

  receipts ExpenseReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseReceipt {
  id        String   @id @default(cuid())
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id])
  filePath  String
  createdAt DateTime @default(now())
}

// A bill that recurs on a schedule (loan payments, subscriptions,
// insurance, licensing) rather than a one-off Expense. Not auto-billed —
// staff use "Log as Expense" here to record it as a real Expense once it's
// actually paid, so recordkeeping stays accurate without manual re-entry.
model RecurringBill {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String // e.g. "Truck", "Google Ads"
  category       String // e.g. "Vehicle Payment", "Advertising"
  amount         Float? // null when variable (e.g. a credit card balance)
  frequency      String // monthly | yearly
  dueDay         Int? // day of month (1-31), for monthly bills
  dueDate        DateTime? // specific annual date, for yearly bills
  paymentMethod  String?
  active         Boolean      @default(true)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// A single row holding the connection to the business's QuickBooks Online
// company, including which account/item new transactions should post to.
// Only exists once a "Connect to QuickBooks" flow has completed.
model QuickBooksConnection {
  id                        String       @id @default(cuid())
  organizationId            String       @unique
  organization              Organization @relation(fields: [organizationId], references: [id])
  realmId                   String
  accessToken               String
  refreshToken              String
  accessTokenExpiresAt      DateTime
  environment               String       @default("sandbox") // sandbox | production
  defaultDepositAccountId   String?
  defaultDepositAccountName String?
  defaultIncomeAccountId    String?
  defaultIncomeAccountName  String?
  defaultExpenseAccountId   String?
  defaultExpenseAccountName String?
  defaultItemId             String?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
}

// The Stripe subscription that bills an organization for its Solo/Team/Pro
// plan — this is Chase's own single platform Stripe account (env-var
// credentials, see src/lib/platformBilling.ts), completely separate from
// StripeConnection below, which is each business's own Stripe account for
// charging their own customers. Only exists once an org upgrades past the
// free "solo" default; Organization.plan is the fast field actually
// checked for gating, this just tracks the Stripe-side relationship.
model PlatformSubscription {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id])
  stripeCustomerId     String
  stripeSubscriptionId String
  status               String // active | past_due | canceled | trialing
  currentPeriodEnd     DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// A business's own Stripe account credentials — pasted from their Stripe
// dashboard rather than an OAuth flow, since (unlike QuickBooks) each
// business is expected to run its own direct Stripe account, not connect
// through a shared platform account. Handles all customer-facing payment
// collection; QuickBooks stays purely for the accounting record (see
// pushInvoicePayment in quickbooks.ts, which a successful Stripe charge
// also calls).
model StripeConnection {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  secretKey      String
  publishableKey String
  webhookSecret  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// A business's own Twilio account credentials — pasted from their Twilio
// console, same "direct account, no OAuth" convention as StripeConnection.
model TwilioConnection {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  accountSid     String
  authToken      String
  // The Twilio number texts send from and receive on, E.164 (e.g. +14785550100).
  phoneNumber    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// One real text message, either direction — the actual conversation
// thread with a customer. Separate from CustomerNote (a manual staff log
// of "what happened", e.g. "called to confirm delivery") since this is an
// automatically-populated record of real sent/received SMS traffic.
model CustomerSmsMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  direction      String       // outbound | inbound
  body           String
  status         String       @default("sent") // sent | delivered | failed | received
  // Twilio's message SID — lets the status-callback webhook find and
  // update this exact row (delivered/failed) after the initial send.
  twilioSid      String?
  createdAt      DateTime     @default(now())
}

// A single row holding the current service agreement text. Edited from
// Settings. Signing snapshots this text so historical signatures stay
// accurate even if the wording changes later.
model ServiceAgreementSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String       @default("Service & Rental Agreement")
  content        String       @default("[Placeholder — replace this with your real service agreement text in Settings before sharing with customers. Consider having a lawyer review it.]")
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
}

// Controls the automated "please leave us a review" email sent a few days
// after a job is fully closed out. Singleton row, same pattern as
// ServiceAgreementSettings — created with defaults on first Settings visit.
model ReviewRequestSettings {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  organization    Organization @relation(fields: [organizationId], references: [id])
  enabled         Boolean      @default(false)
  googleReviewUrl String?
  delayDays       Int          @default(2)
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())
}

// Controls the automated overdue-invoice reminder email. Singleton row,
// same pattern as ReviewRequestSettings — created with defaults on first
// Settings visit.
model InvoiceReminderSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  enabled        Boolean      @default(false)
  delayDays      Int          @default(7) // days past due before the first reminder
  repeatDays     Int          @default(14) // days between repeat reminders while still unpaid
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
}

// Controls whether marking equipment delivered or picked up automatically
// emails the customer (pickup includes the dump weight when it was
// recorded). Singleton row, same pattern as the other *Settings models —
// created with defaults on first Settings visit.
model JobNotificationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  enabled        Boolean      @default(false)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
}

// Controls the margin-alert threshold used on a booking's Job Costing tab
// and the Reports "Job Profitability" table — a job whose
// (revenue-cost)/revenue falls below this percent is flagged. Singleton
// row, same pattern as JobNotificationSettings.
model JobCostingSettings {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id])
  marginAlertPercent Int          @default(20)
  updatedAt          DateTime     @updatedAt
  createdAt          DateTime     @default(now())
}

// Controls the automated "your delivery is coming up" reminder email, sent
// a configurable number of hours before a booking item's scheduled start.
// Singleton row, same pattern as ReviewRequestSettings.
model DeliveryReminderSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  enabled        Boolean      @default(false)
  hoursBefore    Int          @default(24)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
}

// One "search" click on the Leads page — logged purely so we can show how
// many of the monthly free Places API calls (1,000, Enterprise SKU) are
// left, computed as a count of these rather than a stored counter so it's
// always auditable and naturally resets when a new calendar month's
// entries are counted.
model PlacesSearchLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  query          String
  createdAt      DateTime     @default(now())
}

// A local business found via a Google Places search, tracked for sales
// outreach — not a customer yet. Deduped by placeId so re-running a search
// over the same area doesn't create copies; a repeat search just leaves an
// existing lead's status/notes alone and refreshes its basic details.
model Lead {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  // Optional because leads aren't only found via Google Places anymore —
  // one manually logged from a phone call or text has no placeId. Postgres
  // allows multiple NULLs under a unique constraint, so this doesn't
  // affect the upsert-by-placeId dedup that searchAndSaveLeads relies on.
  placeId         String?      @unique
  name            String
  phone           String?
  address         String?
  // How this lead reached us — phone_call | text_message | walk_in |
  // referral | google_places_search | website. Mirrors Customer.leadSource
  // in spirit, but kept separate: a Lead is pre-conversion outreach, a
  // Customer's leadSource is ad-attribution for a real booking.
  source          String?
  // Set once this lead converts to a real Customer (see
  // convertLeadToCustomer / quote acceptance), so the pipeline stays
  // traceable end-to-end instead of a one-way copy with no link back.
  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  // Returned directly by the Places search itself (no separate geocoding
  // call needed) — used to plot leads on the map.
  latitude        Float?
  longitude       Float?
  website         String?
  category        String?
  // The business type as typed into the search box (e.g. "roofers"),
  // before any service area gets appended — kept separate from `category`
  // (Google's own, much noisier classification) so the filter tabs on the
  // Leads page can group by what the business actually searched for.
  tradeCategory   String?
  rating          Float?
  searchQuery     String?
  status          String       @default("new") // new | contacted | interested | quoted | not_interested | customer
  notes           String?
  contactedAt     DateTime?
  // Google Places doesn't return email addresses, so this is filled in by
  // hand (usually found on the business's own website) before an outreach
  // email can be sent.
  email           String?
  // Filled in automatically by the website-scraping enrichment step (see
  // src/lib/leadEnrichment.ts) — best-effort, since not every business
  // links these on their site, and never overwrites a value staff typed
  // in by hand.
  facebookUrl     String?
  instagramUrl    String?
  linkedinUrl     String?
  // Set the first time enrichment runs against this lead (even if nothing
  // was found), so "Enrich All" can skip leads already attempted instead
  // of re-scraping the same site every time it's clicked.
  enrichedAt      DateTime?
  lastEmailSentAt DateTime?
  // Set via the unsubscribe link in a sequence email (see
  // LeadSequenceEnrollment) — once true, no email sends to this lead
  // again, one-click or automated.
  emailOptOut     Boolean      @default(false)
  // Set by the inbound-reply webhook (src/app/api/webhooks/resend-inbound)
  // when a lead actually replies to a sequence email — distinct from
  // contactedAt, which is set when staff manually mark a lead contacted.
  repliedAt       DateTime?
  // Comma-separated, free-form — same storage pattern as Customer.tags
  // (see src/lib/tags.ts). Used for both general qualification tags
  // ("Hot Lead", "Referral") and location tags (service area names),
  // which share one field rather than two since a tag is a tag either way.
  tags            String       @default("")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sequenceEnrollments LeadSequenceEnrollment[]
  emailSends          LeadEmailSend[]
  quotes              Quote[]
}

// A full history of every outreach email actually sent to a lead — one
// row per send, whether triggered by the one-click "Send" button or a
// sequence step. Unlike Lead.lastEmailSentAt (which only remembers the
// most recent one), this is a real log. Status starts at "sent" and
// moves to "replied" when the inbound webhook matches a reply to this
// send (the most recent still-"sent" row for that lead). "bounced" is
// reserved for a future bounce webhook, not wired up yet.
model LeadEmailSend {
  id            String             @id @default(cuid())
  leadId        String
  lead          Lead               @relation(fields: [leadId], references: [id])
  templateId    String?
  template      LeadEmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subject       String
  status        String             @default("sent") // sent | replied | bounced
  sentAt        DateTime           @default(now())
  // Resend's own id for this send, returned when the email is submitted
  // — lets the bounce webhook (src/app/api/webhooks/resend-events) match
  // a bounce to exactly this send instead of guessing "the latest one."
  resendEmailId String?
  // manual (one-click Send button) | sequence_auto (daily cron) |
  // sequence_manual (due-list "Send" button). Only sequence_auto counts
  // against the daily sending cap (see LeadOutreachSettings) — a human
  // clicking Send is already self-paced.
  source        String             @default("manual")
}

// Controls the daily cap on fully-automated sequence sends (the cron),
// so a large backlog of due leads doesn't all fire in one burst — that
// pattern reads as automated/spammy and can hurt a sending domain's
// reputation, especially a newer one. Singleton row, same pattern as
// the other *Settings models.
model LeadOutreachSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  dailySendCap   Int          @default(25)
  // Straight-line miles from the yard (see branding.yardLatitude/
  // yardLongitude) beyond which a lead with known coordinates gets an
  // "outside service area" flag on the Leads page. Informational only —
  // doesn't hide or block anything, just a visible heads-up.
  serviceRadiusMiles Int      @default(30)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// A named, ordered set of outreach emails (e.g. "Roofers — 3 Touch") built
// from existing LeadEmailTemplate rows. `autoSend` decides whether the
// daily cron sends each step by itself once due, or whether it just
// becomes a "due" item a staff member sends with one click — same
// mechanism either way, just who pulls the trigger.
model EmailSequence {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  autoSend       Boolean      @default(false)
  // Master switch — an inactive sequence stops advancing every
  // enrollment (auto or manual) and can't take new enrollments, without
  // deleting its history.
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  steps       SequenceStep[]
  enrollments LeadSequenceEnrollment[]
}

// One email in a sequence. delayDays counts from enrollment for step 1,
// or from the previous step's send for step 2+.
model SequenceStep {
  id         String            @id @default(cuid())
  sequenceId String
  sequence   EmailSequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order      Int
  delayDays  Int
  templateId String
  template   LeadEmailTemplate @relation(fields: [templateId], references: [id])
  createdAt  DateTime          @default(now())

  @@unique([sequenceId, order])
}

// One lead's progress through one sequence. currentStep is the order of
// the last step actually sent (0 = none sent yet). Stops advancing the
// moment the lead's status moves off "new" — the only reliable signal
// available without inbound-reply detection — or on unsubscribe.
model LeadSequenceEnrollment {
  id            String        @id @default(cuid())
  leadId        String
  lead          Lead          @relation(fields: [leadId], references: [id])
  sequenceId    String
  sequence      EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  currentStep   Int           @default(0)
  status        String        @default("active") // active | completed | stopped
  stoppedReason String? // status_changed | unsubscribed | no_email | manual | replied | bounced
  enrolledAt    DateTime      @default(now())
  lastSentAt    DateTime?
  nextDueAt     DateTime?
  updatedAt     DateTime      @updatedAt

  @@unique([leadId, sequenceId])
}

// A reusable outreach message for the Leads page — e.g. one for roofers,
// one for general contractors. {{businessName}} in the subject/body gets
// swapped for the lead's name when sent. Kept separate from EmailTemplate
// (which covers fixed system events like delivery/pickup) since these are
// freeform, user-created, and there can be any number of them.
model LeadEmailTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  subject        String
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sequenceSteps SequenceStep[]
  emailSends    LeadEmailSend[]
}

// A reusable outreach message for the Win-Back page — e.g. "we miss you"
// with a discount. {{customerName}} in the subject/body gets swapped for
// the customer's name when sent. Kept as its own list, separate from
// LeadEmailTemplate, since cold-outreach messaging and win-back messaging
// read very differently even though the sending mechanism is identical.
model WinBackEmailTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  subject        String
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sends WinBackSend[]
}

// One outreach attempt against a lapsed customer — created every time a
// Win-Back template is sent (single or bulk). This is the source of truth
// for "have we reached out, and what happened" — status starts at "sent"
// and staff update it as they hear back, same idea as Lead.status but
// scoped per send instead of per customer, so a customer can have more
// than one campaign wave in their history.
model WinBackSend {
  id         String                @id @default(cuid())
  customerId String
  customer   Customer              @relation(fields: [customerId], references: [id])
  templateId String?
  template   WinBackEmailTemplate? @relation(fields: [templateId], references: [id])
  status     String                @default("sent") // sent | responded | booked | not_interested
  sentAt     DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

// Controls what counts as "lapsed" on the Win-Back page. Singleton row,
// same pattern as ReviewRequestSettings — created with defaults on first
// Settings visit. No enabled/automation flag: win-back is always a
// staff-triggered one-click send, never an automated cron.
model WinBackSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  lapsedDays     Int          @default(90)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
}

// A saved city/area (e.g. "Byron, GA") that Lead searches run against
// automatically, so a search only needs a business type ("roofers") instead
// of retyping the whole service area every time. A search with no saved
// areas just runs the typed query as-is.
model ServiceArea {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
}

// A city/county where street placement requires a permit — configured in
// Settings so the booking detail page's permit checklist only shows up
// when it's actually relevant, instead of on every booking.
model PermitArea {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
}

// A named block of HTML a business owner writes/pastes and saves for reuse
// on their own website — separate from the auto-generated widget code
// (which always reflects live pricing/categories and isn't stored here).
model WebsiteSnippet {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  html           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
}

// One staff member's worked span, either self-logged via the Clock
// In/Out button (source "clock") or hand-entered after the fact
// (source "manual"). hourlyRate snapshots User.hourlyRate at creation
// (same precedent as Quote.amount) so a later rate change never
// rewrites already-logged time.
model TimeEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  bookingId      String?
  booking        Booking?     @relation(fields: [bookingId], references: [id])
  clockIn        DateTime
  clockOut       DateTime?
  hourlyRate     Float?
  source         String       @default("manual") // manual | clock
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// One org's connection to a Google Business Profile location, cloned
// structurally from QuickBooksConnection — the only other real
// OAuth2+refresh-token integration in this app. One location per org.
model GoogleBusinessProfileConnection {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id])
  accountId            String
  locationId           String?
  locationName         String?
  accessToken          String
  refreshToken         String
  accessTokenExpiresAt DateTime
  // Lets staff pause the daily auto-sync without fully disconnecting (and
  // losing the location selection) — manual "Sync Now" on the Reviews page
  // still works regardless of this flag.
  syncEnabled          Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// A review synced in from Google (never created here). Replies are
// always a manual, staff-composed action — replyPostedAt is only set
// once a reply has actually been pushed back to Google.
model GoogleReview {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  googleReviewId  String       @unique
  reviewerName    String
  starRating      Int
  comment         String?
  createTime      DateTime
  replyComment    String?
  replyUpdateTime DateTime?
  replyPostedAt   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// A staff-configured "when X happens, do Y" rule. v1 caps a rule at one
// trigger plus at most one flat condition, and limits actions to
// send_email/send_sms/create_customer_note — no mutating actions.
// Owner-only to create/edit given the blast-radius risk.
model AutomationRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String

  triggerEntity String // lead | booking | invoice | quote | customer
  triggerField  String @default("status")
  triggerValue  String? // null = pure-existence trigger (e.g. customer created)

  conditionField    String?
  conditionOperator String? // equals | not_equals | greater_than | less_than
  conditionValue    String?

  actionType    String // send_email | send_sms | create_customer_note
  actionSubject String? // send_email only
  actionBody    String // {{var}} interpolated, same syntax as EmailTemplate

  enabled   Boolean  @default(false)
  maxPerRun Int      @default(25)
  maxPerDay Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executions AutomationRuleExecution[]
}

// The generalized version of the *SentAt / lastReminderSentAt marker
// every existing cron feature already uses — the fire-once guard that
// stops a rule from re-triggering on an entity it's already acted on.
model AutomationRuleExecution {
  id         String         @id @default(cuid())
  ruleId     String
  rule       AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  entityType String // Lead | Booking | Invoice | Quote | Customer
  entityId   String
  status     String   @default("sent") // sent | failed
  error      String?
  executedAt DateTime @default(now())

  @@unique([ruleId, entityType, entityId])
}

// Hard daily ceiling on total automated actions across every rule
// combined for one org — the outermost safety valve, independent of
// each individual rule's own maxPerDay.
model AutomationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  dailyActionCap Int          @default(200)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
}

// Read-only OAuth link to one Google Ads account per org — mirrors
// QuickBooksConnection/GoogleBusinessProfileConnection exactly. Only the
// "adwords" (read/report) scope is requested; nothing in this app is
// permitted to call a mutate/write endpoint on the Google Ads API.
model GoogleAdsConnection {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id])
  // The Google Ads account being reported on (10-digit, no dashes).
  customerId           String
  // Manager (MCC) account ID, required in the login-customer-id header
  // when the connected Google login accesses the target account through
  // a manager account rather than directly.
  loginCustomerId      String?
  accessToken          String
  refreshToken         String
  accessTokenExpiresAt DateTime
  lastSyncedAt         DateTime?
  lastSyncError        String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// One campaign's metrics for one day — upserted by the daily sync, so a
// re-run never double-counts. Cost is stored in whole dollars (converted
// from the API's cost_micros at fetch time), matching every other money
// field in this schema.
model AdsPerformance {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           DateTime
  campaignId     String
  campaignName   String
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  cost           Float        @default(0)
  conversions    Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, campaignId, date])
}

// A plain-language, human-reviewed-only finding — never auto-executed.
// Shared across Google Ads (Phase 1) and Search Console (Phase 2) via
// `source`, so Phase 2 doesn't need its own table for the same "here's
// something worth looking at" pattern. relatedEntityId (a campaignId,
// search term, or query+page) plus the unique constraint below makes
// each sync idempotent — the same finding is updated in place, not
// duplicated, and a staff dismissal sticks until the underlying
// condition actually changes.
model MarketingRecommendation {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  source          String // google_ads | search_console
  type            String // negative_keyword | underperforming_ad_group | page_two_opportunity | declining_ctr
  title           String
  detail          String
  status          String       @default("open") // open | dismissed | actioned
  relatedEntityId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, source, type, relatedEntityId])
}

// Read-only OAuth link to one verified Search Console property per org —
// same shape as GoogleAdsConnection/GoogleBusinessProfileConnection.
// Requesting only the readonly scope means nothing in this app can submit
// a sitemap, request indexing, or change anything about the property.
model SearchConsoleConnection {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id])
  // Search Console's own site identifier — either a URL-prefix property
  // ("https://mobidumpsters.com/") or a domain property ("sc-domain:
  // mobidumpsters.com"), whichever the connected login has verified.
  siteUrl              String
  accessToken          String
  refreshToken         String
  accessTokenExpiresAt DateTime
  lastSyncedAt         DateTime?
  lastSyncError        String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// One (query, page) pair's Search Analytics numbers for one weekly pull —
// upserted so a re-run never double-counts. serviceArea/serviceType are
// populated by classifyQuery() at fetch time (keyword match against the
// 5 service-area towns and 4 service types) so Phase 3's dashboard can
// filter/group without re-parsing query text on every read.
model SeoPerformance {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  weekStart      DateTime
  query          String
  page           String
  clicks         Int          @default(0)
  impressions    Int          @default(0)
  ctr            Float        @default(0)
  position       Float        @default(0)
  serviceArea    String? // Macon | Warner Robins | Perry | Fort Valley | Milledgeville
  serviceType    String? // dumpster_rental | junk_removal | demolition | material_delivery
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, weekStart, query, page])
}

// A record of one customer agreeing to the service agreement — either as a
// required step of the online booking flow, or via a standalone link sent
// manually. Stores a snapshot of the exact text agreed to.
model SignedAgreement {
  id             String   @id @default(cuid())
  agreementTitle String
  agreementText  String
  signerName     String
  signerEmail    String?
  signerPhone    String?
  signerAddress  String?
  ipAddress      String?
  signatureUrl   String?
  agreedAt       DateTime @default(now())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  bookingId  String?
  booking    Booking?  @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}
